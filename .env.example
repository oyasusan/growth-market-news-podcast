# AI設定 (どちらか一方を設定)
# OpenRouter (無料枠利用: https://openrouter.ai/)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemma-3-27b-it:free

# Gemini (無料枠利用: https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# AI優先順位: openrouter / gemini / local
AI_PROVIDER=openrouter

# TTS設定
TTS_VOICE=ja-JP-NanamiNeural
TTS_RATE=+10%
TTS_VOLUME=+0%

# GitHub Pages設定
GITHUB_REPOSITORY=your_username/grawth-podcast
PODCAST_BASE_URL=https://your_username.github.io/grawth-podcast

# Podcast情報
PODCAST_TITLE=グロース市場ニュース
PODCAST_DESCRIPTION=東証グロース市場の最新動向を毎朝お届けする音声ニュースです。教育目的であり投資助言ではありません。
PODCAST_AUTHOR=grawth-podcast
PODCAST_EMAIL=your_email@example.com
PODCAST_IMAGE_URL=https://your_username.github.io/grawth-podcast/artwork.png

# ログレベル: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
